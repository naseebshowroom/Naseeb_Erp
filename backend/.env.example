NODE_ENV=production
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/naseeb_erp?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_jwt_secret_minimum_64_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_different_from_above
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# CORS — Production frontend
FRONTEND_URL=https://naseeb-erp.vercel.app
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=500

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Puppeteer (Railway/Docker)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
