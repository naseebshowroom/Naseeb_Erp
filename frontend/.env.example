# ── Frontend Environment Variables ──────────────────────

# API base URL (proxied via Vite in dev, real URL in prod)
VITE_API_URL=http://localhost:5000/api

# App metadata
VITE_APP_NAME=Kiraya ERP
VITE_APP_VERSION=1.0.0

# Cloudinary (for direct frontend uploads if needed)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=kiraya_unsigned
