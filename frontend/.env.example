# ── Frontend Environment Variables ──────────────────────

# API base URL — local dev
VITE_API_URL=http://localhost:5000/api

# API base URL — production (Railway)
# VITE_API_URL=https://naseeb-erp-backend-production.up.railway.app/api

# App metadata
VITE_APP_NAME=Naseeb ERP
VITE_APP_VERSION=1.0.0

# Cloudinary (for direct frontend uploads if needed)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=naseeb_unsigned
